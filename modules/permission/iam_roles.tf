resource "aws_iam_role" "temperature_role" {
  name = "data-lake-temp-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Action = "sts:AssumeRole"
        Effect = "Allow"
        Principal = {
		  AWS = "arn:aws:iam::${var.analyst_account}:root"
          Service = "athena.amazonaws.com"
        }
      }
    ]
  })
}

